<Window x:Class="WpfApp3.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС предприятия - Авторизация" Height="600" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="Авторизация в системе" 
                          FontSize="24" FontWeight="Bold" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,20"/>
                <!-- Логин -->
                <TextBlock Text="Логин:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="30" Margin="0,0,0,10"/>
                <!-- Пароль -->
                <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,10"/>
                <!-- Капча -->
                <TextBlock Text="Соберите пазл для проверки:" 
                          FontWeight="Bold" Margin="0,20,0,10"/>
                <Canvas x:Name="captchaCanvas" 
                       Height="280" Width="380"
                       Background="WhiteSmoke"/>
                <Button x:Name="btnResetCaptcha" 
                       Content="Сбросить капчу"
                       Click="BtnResetCaptcha_Click"
                       Margin="0,10,0,10"/>
                <!-- Кнопка входа -->
                <Button x:Name="btnLogin" 
                       Content="Войти"
                       Height="40" Width="120"
                       Click="BtnLogin_Click"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
                <!-- Информация о попытках -->
                <TextBlock x:Name="txtAttemptsInfo" 
                          Text="Осталось попыток: 3"
                          HorizontalAlignment="Center"
                          Margin="0,10,0,0"
                          Foreground="Gray"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
