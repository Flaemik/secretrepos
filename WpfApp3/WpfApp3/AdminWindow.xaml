<Window x:Class="WpfApp3.AdminWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС предприятия - Панель администратора" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Управление пользователями" 
                      FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="txtAdminInfo" 
                      Text="Администратор: " 
                      FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>
        <!-- Основное содержимое -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <!-- Таблица пользователей -->
            <DataGrid x:Name="dgUsers" 
                     Grid.Column="0"
                     AutoGenerateColumns="True"
                     IsReadOnly="True"
                     SelectionChanged="DgUsers_SelectionChanged"
                     Margin="0,0,10,0"/>
            <!-- Панель управления -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Управление пользователем" 
                          FontWeight="Bold" FontSize="16" 
                          Margin="0,0,0,10"/>
                <TextBlock Text="Логин:" Margin="0,5,0,0"/>
                <TextBox x:Name="txtLogin" Height="25"/>
                <TextBlock Text="Пароль:" Margin="0,5,0,0"/>
                <TextBox x:Name="txtPassword" Height="25"/>
                <TextBlock Text="ФИО:" Margin="0,5,0,0"/>
                <TextBox x:Name="txtFullName" Height="25"/>
                <TextBlock Text="Роль:" Margin="0,5,0,0"/>
                <ComboBox x:Name="cmbRole" Height="25" SelectionChanged="CmbRole_SelectionChanged">
                    <ComboBoxItem Content="Администратор"/>
                    <ComboBoxItem Content="Пользователь"/>
                </ComboBox>
                <CheckBox x:Name="chkBlocked" 
                         Content="Заблокирован" 
                         Margin="0,10,0,0"/>
                <Button x:Name="btnAdd" 
                       Content="Добавить пользователя"
                       Click="BtnAdd_Click"
                       Margin="0,10,0,0"/>
                <Button x:Name="btnUpdate" 
                       Content="Обновить данные"
                       Click="BtnUpdate_Click"
                       Margin="0,5,0,0"/>
                <Button x:Name="btnUnblock" 
                       Content="Снять блокировку"
                       Click="BtnUnblock_Click"
                       Margin="0,5,0,0"/>
                <Button x:Name="btnRefresh" 
                       Content="Обновить список"
                       Click="BtnRefresh_Click"
                       Margin="0,5,0,0"/>
                <Button x:Name="btnLogout" 
                       Content="Выйти"
                       Click="BtnLogout_Click"
                       Margin="0,20,0,0"
                       Background="Gray"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
